# === GEMINI ===
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# === META WHATSAPP ===
META_WHATSAPP_TOKEN=your_token_here
META_PHONE_NUMBER_ID=your_phone_number_id
META_VERIFY_TOKEN=munim_verify_2026
META_APP_SECRET=your_app_secret

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === REDIS ===
# Local dev:     redis://localhost:6379/0
# Docker Compose: redis://redis:6379/0
# Upstash free:  rediss://your-endpoint.upstash.io:6379 (set TOKEN below)
UPSTASH_REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_TOKEN=

# === GSTIN VERIFICATION API ===
GSTIN_API_KEY=your_key_here
GSTIN_API_BASE_URL=https://api.deepvue.tech/v1

# === PUBLIC URL ===
PUBLIC_URL=https://your-ngrok-or-railway.app

# === APP ===
ENVIRONMENT=development
FASTAPI_PORT=8000
DEBUG=true
